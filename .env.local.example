# ============================================================
# .env.local.example — Copiar a .env.local y completar valores
# ============================================================

# ─── Supabase (Frontend + Auth) ─────────────────────────────
# Obtener en: https://supabase.com/dashboard → Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://XXXXXXXXXXXXXXXXXXXX.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role key (solo backend — NUNCA exponer al frontend)
# Obtener en: Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Supabase Direct DB Connection ──────────────────────────
# Para scripts de migración con pg COPY (máxima performance)
# Obtener en: Settings → Database → Connection string
# IMPORTANTE: usar puerto 5432 (Session mode), NO 6543 (Transaction mode)
# porque pg-copy-streams requiere una sesión persistente
SUPABASE_DB_HOST=db.XXXXXXXXXXXXXXXXXXXX.supabase.co
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=tu-password-de-supabase
SUPABASE_DB_SSL=true

# Forma alternativa (URL completa - compatible con otras herramientas)
SUPABASE_DB_URL=postgresql://postgres:tu-password@db.XXXXXXXXXXXXXXXXXXXX.supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:tu-password@db.XXXXXXXXXXXXXXXXXXXX.supabase.co:5432/postgres

# ─── MySQL Local (Origen de datos) ──────────────────────────
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=tu-password-mysql
MYSQL_DATABASE=master_test

# ─── Inception AI ───────────────────────────────────────────
# Obtener en: https://inceptionlabs.ai → API Keys
INCEPTION_API_KEY=tu-inception-api-key

# ─── App ─────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_SECRET=genera-un-string-aleatorio-de-32-chars
NODE_ENV=development
