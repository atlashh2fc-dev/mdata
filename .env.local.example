# ============================================================
# .env.local.example — Copiar a .env.local y completar valores
# ============================================================

# ─── Supabase (Frontend + Auth) ─────────────────────────────
# Obtener en: https://supabase.com/dashboard → Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://XXXXXXXXXXXXXXXXXXXX.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role key (solo backend — NUNCA exponer al frontend)
# Obtener en: Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Supabase Direct DB Connection ──────────────────────────
# Para scripts de migración con pg COPY (máxima performance)
# Obtener en: Settings → Database → Connection string
# IMPORTANTE: usar puerto 5432 (Session mode), NO 6543 (Transaction mode)
# porque pg-copy-streams requiere una sesión persistente
SUPABASE_DB_HOST=db.XXXXXXXXXXXXXXXXXXXX.supabase.co
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=tu-password-de-supabase
SUPABASE_DB_SSL=true

# Forma alternativa (URL completa - compatible con otras herramientas)
SUPABASE_DB_URL=postgresql://postgres:tu-password@db.XXXXXXXXXXXXXXXXXXXX.supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:tu-password@db.XXXXXXXXXXXXXXXXXXXX.supabase.co:5432/postgres

# ─── MySQL Local (Origen de datos) ──────────────────────────
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=tu-password-mysql
MYSQL_DATABASE=master_test

# ─── Inception AI ───────────────────────────────────────────
# Obtener en: https://inceptionlabs.ai → API Keys
INCEPTION_API_KEY=tu-inception-api-key

# ─── Brave Search API ───────────────────────────────────────
# Opcional, pero recomendado para el scraping de contactos web.
# Obtener en: https://api-dashboard.search.brave.com/
BRAVE_SEARCH_API_KEY=tu-brave-search-api-key

# ─── CRM registro-intel → feedback operativo ────────────────
# Proyecto Supabase origen del contact center.
REGISTRO_INTEL_SUPABASE_URL=https://xxxxxxxx.supabase.co
REGISTRO_INTEL_SUPABASE_SERVICE_ROLE_KEY=service-role-del-crm
REGISTRO_INTEL_CURSOR_COLUMN=source_updated_at
REGISTRO_INTEL_SOURCE_ID_COLUMN=source_record_id

# Vista o tabla expuesta por el CRM para export incremental de feedback.
# Recomendado: una vista estable como crm_feedback_export_v1
REGISTRO_INTEL_FEEDBACK_SOURCE=crm_feedback_export_v1

# Alternativa recomendada para integración desacoplada:
# exponer un endpoint interno estable en el CRM y consumirlo desde un job batch.
REGISTRO_INTEL_API_URL=https://registro-intel.tu-dominio.cl
REGISTRO_INTEL_API_KEY=token-interno-del-crm
REGISTRO_INTEL_SYNC_SINCE=2026-01-01T00:00:00Z
REGISTRO_INTEL_PAGE_SIZE=1000

# Nombre lógico de la fuente remota para trazabilidad local.
REGISTRO_INTEL_SOURCE_SYSTEM=registro_intel

# Token compartido para ingest push/webhook desde el CRM hacia este proyecto.
CRM_FEEDBACK_INGEST_TOKEN=define-un-token-interno-seguro

# URL interna de este proyecto para jobs de feedback.
RUT_INTELLIGENCE_API_URL=http://localhost:3000

# ─── App ─────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_SECRET=genera-un-string-aleatorio-de-32-chars
NODE_ENV=development
