{
  "name": "rut-intelligence",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "ops:export:csv": "node --env-file=.env.local scripts/master-sync/export-mysql-to-csv.mjs",
    "ops:load:csv": "node --env-file=.env.local scripts/master-sync/load-csv-to-postgres.mjs",
    "ops:sync:master": "node --env-file=.env.local scripts/master-sync/sync-master-data.mjs",
    "ops:sync:master:replace": "node --env-file=.env.local scripts/master-sync/sync-master-data.mjs --mode=replace",
    "ops:import:csv": "node --env-file=.env.local scripts/master-sync/import-csv-to-supabase.mjs",
    "ops:padron2024:prepare": "node --env-file=.env.local scripts/master-sync/prepare-padron2024-txt.mjs",
    "ops:padron2024:load": "node --env-file=.env.local scripts/master-sync/load-padron2024-to-postgres.mjs",
    "ops:padron2024:catalog": "node --env-file=.env.local scripts/master-sync/load-padron2024-to-postgres.mjs --metadata-only",
    "ops:padron2024:import": "node --env-file=.env.local scripts/master-sync/prepare-padron2024-txt.mjs && node --env-file=.env.local scripts/master-sync/load-padron2024-to-postgres.mjs",
    "ops:padron2024:fix-canonical": "node --env-file=.env.local scripts/master-sync/fix-padron2024-local-chunks.mjs",
    "ops:personas-master:rebuild-stage": "node --env-file=.env.local scripts/master-sync/rebuild-personas-master-canonical.mjs --rebuild-stage",
    "ops:personas-master:rebuild-apply": "node --env-file=.env.local scripts/master-sync/rebuild-personas-master-canonical.mjs --apply",
    "ops:consolidado": "node --env-file=.env.local scripts/master-sync/export-consolidado.mjs",
    "ops:consolidado:replace": "node --env-file=.env.local scripts/master-sync/export-consolidado.mjs --mode=replace",
    "ops:consolidado:rest": "node --env-file=.env.local scripts/master-sync/export-consolidado-rest.mjs",
    "ops:consolidado:rest:replace": "node --env-file=.env.local scripts/master-sync/export-consolidado-rest.mjs --mode=replace",
    "ops:equifax:import:sales": "node --env-file=.env.local scripts/equifax/import-sales-xlsx.mjs",
    "ops:verify": "node --env-file=.env.local scripts/master-sync/verify-migration.mjs",
    "ops:backfill:company-contacts": "node --env-file=.env.local scripts/master-sync/backfill-company-contacts.mjs",
    "ops:sync:crm-feedback": "node --env-file=${ENV_FILE:-.env.production} scripts/crm-feedback-sync/sync-registro-intel.mjs",
    "ops:apply:crm-contract": "node --env-file=${ENV_FILE:-.env.production} scripts/crm-contract/apply-registro-intel-contract.mjs",
    "ops:push:crm-actions": "node --env-file=${ENV_FILE:-.env.production} scripts/crm-actions-sync/push-registro-intel.mjs",
    "ops:sync:crm-loop": "npm run ops:sync:crm-feedback && npm run ops:push:crm-actions"
  },
  "dependencies": {
    "@supabase/ssr": "^0.5.1",
    "@supabase/supabase-js": "^2.45.4",
    "@tanstack/react-query": "^5.59.0",
    "@tanstack/react-table": "^8.20.5",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "duck-duck-scrape": "2.2.7",
    "lucide-react": "^0.453.0",
    "mysql2": "^3.12.0",
    "next": "15.0.7",
    "papaparse": "^5.4.1",
    "pg": "^8.13.1",
    "pg-copy-streams": "^7.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.15.4",
    "tailwind-merge": "^2.5.4",
    "xlsx": "^0.18.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "@types/papaparse": "^5.3.14",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "15.0.7",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3"
  }
}
